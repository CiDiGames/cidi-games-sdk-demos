{
  "name": "@cidi-game-sdk-demos/nodejs-server",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS demo server for CIDI Game SDK OpenAPI integration.",
  "scripts": {
    "dev": "node --watch -r ts-node/register src/main.ts",
    "start": "ts-node src/main.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "dotenv": "^16.4.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
